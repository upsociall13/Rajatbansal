{
  "entities": {
    "Booking": {
      "title": "Booking",
      "description": "A consultation booking request from a client.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the client."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the client."
        },
        "phone": {
          "type": "string",
          "description": "Phone number of the client."
        },
        "birthDate": {
          "type": "string",
          "format": "date",
          "description": "Birth date of the client."
        },
        "birthTime": {
          "type": "string",
          "description": "Birth time of the client."
        },
        "birthLocation": {
          "type": "string",
          "description": "Birth location of the client."
        },
        "message": {
          "type": "string",
          "description": "Optional message from the client."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "reviewed", "confirmed", "cancelled"],
          "description": "Status of the booking request."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the booking was created."
        },
        "uid": {
          "type": "string",
          "description": "The user ID of the client (if authenticated)."
        }
      },
      "required": ["name", "email", "phone", "birthDate", "birthTime", "birthLocation", "status", "createdAt"]
    },
    "Contact": {
      "title": "Contact",
      "description": "A simple contact form submission.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the person contacting."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email of the person contacting."
        },
        "message": {
          "type": "string",
          "description": "The message sent."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the contact message was sent."
        }
      },
      "required": ["name", "email", "message", "createdAt"]
    }
  },
  "firestore": {
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Collection of consultation booking requests."
    },
    "/contacts/{contactId}": {
      "schema": "Contact",
      "description": "Collection of contact form submissions."
    }
  }
}
